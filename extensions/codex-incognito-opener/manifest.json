{
  "manifest_version": 3,
  "name": "Codex Pool 自动授权助手",
  "version": "2.5.0",
  "description": "v2.5 修复 account_deactivated 死号 bug。每个动作只执行一次，绝不重试，避免 OpenAI 检测多次失败登录直接停号。",
  "permissions": ["tabs", "storage", "scripting", "cookies", "browsingData"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://auth.openai.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Codex Pool 助手"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content_pool.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://auth.openai.com/*"],
      "js": ["content_auth.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content_chatgpt.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
